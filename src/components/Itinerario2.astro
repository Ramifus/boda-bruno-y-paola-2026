---
// Itinerario2.astro - Segundo día
---

<section class="px-4 relative overflow-hidden py-6">
    <div class="max-w-5xl mx-auto relative z-10">
        <div class="max-w-3xl mx-auto relative">
            <!-- Título -->
            <div class="text-center mb-6 titulo-itinerario2 opacity-0">
                <h2
                    class="font-charm text-2xl md:text-3xl lg:text-3xl text-[#9C7A2E] font-bold mb-3"
                >
                    ITINERARIO
                </h2>
                <div class="flex items-center justify-center gap-3">
                    <div class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#9C7A2E]"></div>
                    <div class="w-2 h-2 rounded-full bg-[#9C7A2E]"></div>
                    <div class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#9C7A2E]"></div>
                </div>
            </div>

            <div class="relative px-4 md:px-8">
                <!-- Línea central -->
                <div
                    class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[#9C7A2E] via-[#B89551] to-[#9C7A2E] rounded-full shadow-sm linea-central2 opacity-0"
                >
                </div>

                <div class="space-y-0" id="eventos-container2">
                    <!-- Corazón 1 -->
                    <div class="flex justify-center py-1">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#9C7A2E] to-[#7D6124] flex items-center justify-center relative z-10 corazon-item2 shadow-md opacity-0">
                            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                            </svg>
                        </div>
                    </div>

                    <!-- Evento 1: Recojo de padrinos -->
                    <div class="evento-item2 grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0">
                        <div class="flex flex-col items-center justify-center px-2 md:px-4 imagen-izq2">
                            <div class="w-14 h-14 md:w-16 md:h-16 lg:w-20 lg:h-20 transform transition-transform duration-300 hover:scale-110">
                                <img
                                    src="/iconos/recepcion.png"
                                    alt="Icono Recojo"
                                    class="w-full h-full object-contain dorado-filter"
                                />
                            </div>
                        </div>
                        <div class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-der2">
                            <p class="font-charm text-lg md:text-2xl lg:text-2xl xl:text-3xl text-[#0F3D2E] font-bold leading-tight">
                                Recojo de padrinos
                            </p>
                            <p class="font-charm text-base md:text-2xl lg:text-2xl xl:text-3xl text-[#9C7A2E] mt-0.5">
                                10:00 a.m.
                            </p>
                        </div>
                    </div>

                    <!-- Corazón 2 -->
                    <div class="flex justify-center py-1">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#9C7A2E] to-[#7D6124] flex items-center justify-center relative z-10 corazon-item2 shadow-md opacity-0">
                            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                            </svg>
                        </div>
                    </div>

                    <!-- Evento 2: Llegada al salón y challa de regalos -->
                    <div class="evento-item2 grid grid-cols-2 gap-4 md:gap-8 py-1 opacity-0">
                        <div class="flex flex-col items-center justify-center px-2 md:px-4 text-center texto-izq2">
                            <p class="font-charm text-lg md:text-2xl lg:text-2xl xl:text-3xl text-[#0F3D2E] font-bold leading-tight">
                                Llegada al salón y challa de regalos
                            </p>
                            <p class="font-charm text-base md:text-2xl lg:text-2xl xl:text-3xl text-[#9C7A2E] mt-0.5">
                                14:00 p.m.
                            </p>
                        </div>
                        <div class="flex flex-col items-center justify-center px-2 md:px-4 imagen-der2">
                            <div class="w-14 h-14 md:w-16 md:h-16 lg:w-20 lg:h-20 transform transition-transform duration-300 hover:scale-110">
                                <img
                                    src="/iconos/brindis.png"
                                    alt="Icono Llegada Salón"
                                    class="w-full h-full object-contain dorado-filter"
                                />
                            </div>
                        </div>
                    </div>

                    <!-- Corazón Final -->
                    <div class="flex justify-center py-1">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#9C7A2E] to-[#7D6124] flex items-center justify-center relative z-10 corazon-item2 shadow-md opacity-0">
                            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .font-charm {
        font-family: "Charm", cursive;
    }

    .evento-item2 p {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .evento-item2:hover p:first-of-type {
        color: #9c7a2e;
        transform: scale(1.08);
        text-shadow: 0 2px 8px rgba(156, 122, 46, 0.3);
    }

    .corazon-item2 {
        filter: drop-shadow(0 4px 12px rgba(156, 122, 46, 0.5));
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .corazon-item2:hover {
        transform: scale(1.2) rotate(10deg);
        filter: drop-shadow(0 8px 20px rgba(156, 122, 46, 0.7));
    }

    .evento-item2 img.dorado-filter {
        filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
            saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%)
            drop-shadow(0 4px 10px rgba(156, 122, 46, 0.2));
        transition: filter 0.3s ease, transform 0.3s ease;
    }

    .evento-item2 img.dorado-filter:hover {
        filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
            saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%)
            drop-shadow(0 6px 16px rgba(156, 122, 46, 0.35));
    }

    .linea-central2 {
        box-shadow: 0 0 15px rgba(156, 122, 46, 0.3);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initItinerario2 = () => {
        gsap.set(".titulo-itinerario2", { opacity: 0, y: -30 });
        gsap.set(".linea-central2", { opacity: 0, scaleY: 0 });
        gsap.set(".corazon-item2", { opacity: 0, scale: 0 });
        gsap.set(".evento-item2", { opacity: 0 });
        gsap.set(".imagen-izq2", { x: -60 });
        gsap.set(".texto-izq2", { x: -60 });
        gsap.set(".imagen-der2", { x: 60 });
        gsap.set(".texto-der2", { x: 60 });

        ScrollTrigger.create({
            trigger: ".titulo-itinerario2",
            start: "top 85%",
            once: true,
            onEnter: () => {
                gsap.to(".titulo-itinerario2", {
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    ease: "power3.out",
                });
            },
        });

        ScrollTrigger.create({
            trigger: "#eventos-container2",
            start: "top 80%",
            end: "top 20%",

            onEnter: () => {
                const tl = gsap.timeline();

                tl.to(".linea-central2", { opacity: 1, scaleY: 1, duration: 1.5, ease: "power2.out", transformOrigin: "top center" }, 0)
                    .to(".corazon-item2", { opacity: 1, scale: 1, duration: 0.8, ease: "back.out(1.7)" }, 0)
                    .to(".evento-item2", { opacity: 1, duration: 1, ease: "power3.out" }, 0)
                    .to(".imagen-izq2, .texto-izq2", { x: 0, duration: 1, ease: "power3.out" }, 0)
                    .to(".imagen-der2, .texto-der2", { x: 0, duration: 1, ease: "power3.out" }, 0);
            },

            onLeaveBack: () => {
                const tl = gsap.timeline();

                tl.to(".linea-central2, .corazon-item2, .evento-item2", { opacity: 0, duration: 0.4, ease: "power2.in" }, 0)
                    .to(".linea-central2", { scaleY: 0, duration: 0.4, ease: "power2.in", transformOrigin: "top center" }, 0)
                    .to(".corazon-item2", { scale: 0, duration: 0.4, ease: "power2.in" }, 0)
                    .to(".imagen-izq2, .texto-izq2", { x: -60, duration: 0.4, ease: "power2.in" }, 0)
                    .to(".imagen-der2, .texto-der2", { x: 60, duration: 0.4, ease: "power2.in" }, 0);
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initItinerario2);
    document.addEventListener("astro:page-load", initItinerario2);
</script>

<style>
    .dorado-filter {
        filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
            saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%);
    }
</style>
